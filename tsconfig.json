{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["runtime.ts", "index.ts", "test.ts", "server.ts"],
  "exclude": ["node_modules", "dist", "dist-app", "examples", "dom.ts", "jsx.d.ts"]
}
